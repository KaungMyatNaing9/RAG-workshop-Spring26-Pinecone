# .env.example
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual API keys.
#
#   cp .env.example .env          (macOS / Linux)
#   copy .env.example .env        (Windows Command Prompt)
#
# NEVER commit your real .env file to GitHub.
# It is already listed in .gitignore to protect your keys.
# ─────────────────────────────────────────────────────────────

# Google AI Studio API key
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Pinecone API key
# Get yours at: https://app.pinecone.io → API Keys
PINECONE_API_KEY=

# The name of the Pinecone index you created for this project
# Must be an index with dimension=384 and metric=cosine
PINECONE_INDEX_NAME=rag-workshop
